# ─── F1 Live Race Insight Architecture ───────────────────────────────────────
# Copy this file to .env and fill in your values.

# ─── OpenAI (optional — falls back to rule-based commentary if not set) ──────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=250

# ─── OpenF1 API ───────────────────────────────────────────────────────────────
OPENF1_BASE_URL=https://api.openf1.org/v1
OPENF1_POLL_INTERVAL=2.0       # seconds between polling cycles
OPENF1_TIMEOUT=5.0             # HTTP request timeout (seconds)
OPENF1_MAX_RETRIES=3           # retries on network/timeout errors
ACTIVE_SESSIONS=Race,Sprint    # session types that activate the full trigger pipeline

# ─── Redis (production) ───────────────────────────────────────────────────────
# For local development without Redis, the app uses FakeRedis automatically.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_STATE_TTL=10             # seconds before stale driver state auto-expires
REDIS_MAX_CONNECTIONS=20

# ─── Server ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Mock Simulator (fallback when no live session is active) ─────────────────
TELEMETRY_POLL_INTERVAL=2.5    # seconds between mock telemetry ticks
TRIGGER_CHECK_INTERVAL=1.0     # seconds between trigger evaluations

# ─── RAG (pre-race historical fact generation) ────────────────────────────────
RAG_LOOKBACK_YEARS=3           # seasons of FastF1 data to analyse
