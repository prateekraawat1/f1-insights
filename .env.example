# ─── F1 Live Race Insight Architecture ───────────────────────────────────────
# Copy this file to .env and fill in your values.

# ─── OpenAI (optional — falls back to rule-based commentary if not set) ──────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=250

# ─── Redis (optional — falls back to FakeRedis if no server is running) ──────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ─── Server ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Simulation Speed ────────────────────────────────────────────────────────
TELEMETRY_POLL_INTERVAL=2.5   # seconds between telemetry ticks
TRIGGER_CHECK_INTERVAL=1.0    # seconds between trigger evaluations
